{
    "compilerOptions": {
        "target": "ES2020",
        "module": "es2020",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "lib": [
            "ESNext",
            "DOM"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "**/__tests__/*",
        "cache",
        "playwright",
    ]
}